# LLM provider (optional — without a key, digests use a placeholder summary)
GEMINI_API_KEY=
OPENAI_API_KEY=
AGENT_PROVIDER=gemini
AGENT_MODEL=gemini-2.5-flash
# For AGENT_PROVIDER=ollama (local, no key needed):
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Listings feed. Switch to the Summer2027 repo when SimplifyJobs publishes it:
# LISTINGS_URL=https://raw.githubusercontent.com/SimplifyJobs/Summer2027-Internships/dev/.github/scripts/listings.json
# Comma-separated term tags to keep (default: Summer 2026,Fall 2026)
# FILTER_TERMS=Fall 2026,Summer 2027

# Weekly schedule (daemon): default Monday 09:00
SCHEDULE_DAY_OF_WEEK=mon
SCHEDULE_HOUR=9

# Demo mode: uncomment to run every N seconds instead of weekly
# AGENT_INTERVAL_SECONDS=30

# Minutes without a heartbeat before an in-flight run counts as crashed
STALE_RUN_MINUTES=30
